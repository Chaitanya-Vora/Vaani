# ── AI / LLM Keys ──────────────────────────────────────────────────
# Required for Vision/Text classification
GOOGLE_API_KEY="your_gemini_vision_flash_key_here"
# Required for Voice Note transcription
OPENAI_API_KEY="your_whisper_api_key_here"

# ── WhatsApp Setup ───────────────────────────────────────────────
# Follow the WhatsApp Developer console to get these
WHATSAPP_PHONE_NUMBER_ID="your_phone_id"
WHATSAPP_ACCESS_TOKEN="your_permanent_or_temporary_token"
WHATSAPP_VERIFY_TOKEN="vaani_webhook_verify"

# ── Integrations (OAuth) ─────────────────────────────────────────
# These are used when a user clicks "Connect Integrations" in the Dashboard
NOTION_CLIENT_ID="your_notion_oauth_client_id"
NOTION_CLIENT_SECRET="your_notion_secret"

# ── Database ─────────────────────────────────────────────────────
DATABASE_URL="postgresql+asyncpg://vaani:vaani@localhost:5432/vaani"
REDIS_URL="redis://localhost:6379/0"
